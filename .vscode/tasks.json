      }
    },
    {
      "label": "📦 Check: Version",
      "type": "shell",
      "command": "echo \"Current version: $(node -p \\\"require('./package.json').version\\\")\"",
      "problemMatcher": []
    },
    {
      "label": "🏷️  Push: Tags Only",
      "type": "shell",
      "command": "git push --tags",
      "problemMatcher": []
    }
  ]
